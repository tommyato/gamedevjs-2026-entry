{
  "name": "gamedevjs-2026",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:sim": "esbuild src/simulation.ts --bundle --format=esm --outfile=dist/simulation.mjs --platform=node",
    "build:scripted": "esbuild src/ai-ghost-scripted.ts --bundle --format=esm --outfile=dist/ai-ghost-scripted.mjs --platform=node",
    "verify:layout": "npm run build:sim && node scripts/verify-layout.mjs",
    "verify:scripted-ai": "npm run build:sim && npm run build:scripted && node scripts/verify-scripted-ai.mjs",
    "verify:mp-seed": "node scripts/verify-mp-seed-sync.mjs",
    "verify:name-sync": "node scripts/verify-name-sync.mjs",
    "verify-ui": "node scripts/verify-ui.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "onnxruntime-web": "^1.24.3",
    "three": "^0.183.0"
  },
  "devDependencies": {
    "@types/three": "^0.183.0",
    "playwright": "^1.59.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
